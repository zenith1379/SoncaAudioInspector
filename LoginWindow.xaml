<Window x:Class="SoncaAudioInspector.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ĐĂNG NHẬP HỆ THỐNG" 
        Height="450" 
        Width="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0F0F11"
        AllowsTransparency="True"
        BorderThickness="1"
        BorderBrush="#27272A">
    
    <Window.Resources>
        <!-- Custom text box style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#10B981"/> <!-- Green theme -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom password box style -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#10B981"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0F0F11" CornerRadius="10">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title & Subtitle -->
                <RowDefinition Height="*"/>    <!-- Form Fields -->
                <RowDefinition Height="Auto"/> <!-- Status Area -->
                <RowDefinition Height="Auto"/> <!-- Actions / Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,10,0,25" HorizontalAlignment="Center">
                <TextBlock Text="SONCA AUDIO" 
                           FontWeight="Bold" 
                           FontSize="24" 
                           Foreground="#10B981" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="ĐĂNG NHẬP HỆ THỐNG" 
                           FontSize="12" 
                           Foreground="#71717A" 
                           HorizontalAlignment="Center" 
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Form -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <!-- Username -->
                <TextBlock Text="Email hoặc tài khoản"
                           Foreground="#A1A1AA" 
                           FontSize="13" 
                           Margin="0,0,0,6" 
                           FontWeight="Medium"/>
                <TextBox x:Name="TxtUsername" 
                          Style="{StaticResource ModernTextBox}"
                          TextChanged="TxtUsername_TextChanged"/>
                <TextBlock x:Name="LblErrorUsername" 
                            Text="Tên đăng nhập không được để trống." 
                            Foreground="#EF4444" 
                            FontSize="11" 
                            Margin="0,4,0,12" 
                            Visibility="Collapsed"/>

                <!-- Password -->
                <TextBlock Text="Mật khẩu" 
                           Foreground="#A1A1AA" 
                           FontSize="13" 
                           Margin="0,6,0,6" 
                           FontWeight="Medium"/>
                <PasswordBox x:Name="TxtPassword" 
                             Style="{StaticResource ModernPasswordBox}"
                             PasswordChanged="TxtPassword_PasswordChanged"/>
                <TextBlock x:Name="LblErrorPassword" 
                            Text="Mật khẩu không được để trống." 
                            Foreground="#EF4444" 
                            FontSize="11" 
                            Margin="0,4,0,12" 
                            Visibility="Collapsed"/>

                <CheckBox x:Name="ChkRememberLogin"
                          Content="Ghi nhớ đăng nhập trên máy này"
                          Foreground="#A1A1AA"
                          FontSize="12"
                          Margin="0,0,0,4"/>
            </StackPanel>

            <!-- Status Indicator -->
            <TextBlock x:Name="LblStatus" 
                       Grid.Row="2" 
                       Text="" 
                       Foreground="#EF4444" 
                       FontSize="13" 
                       TextAlignment="Center" 
                       Margin="0,0,0,15"
                       TextWrapping="Wrap"
                       FontWeight="Medium"/>

            <!-- Buttons -->
            <UniformGrid Grid.Row="3" Columns="2" Rows="1" Height="42" Margin="0,5,0,5">
                <Button x:Name="BtnExit" 
                        Content="Thoát" 
                        Click="BtnExit_Click"
                        Background="Transparent"
                        Foreground="#A1A1AA"
                        BorderBrush="#27272A"
                        BorderThickness="1"
                        Cursor="Hand"
                        Margin="0,0,8,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="BtnLogin" 
                        Content="Đăng nhập" 
                        IsDefault="True"
                        Click="BtnLogin_Click"
                        Background="#10B981"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Margin="8,0,0,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </UniformGrid>
        </Grid>
    </Border>
</Window>
