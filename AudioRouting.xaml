<UserControl x:Class="SoncaAudioInspector.AudioRouting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SoncaAudioInspector"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1200"
             Background="#0E0E10" Foreground="#E4E4E7">
             
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Controls & Setup -->
        <Border Grid.Column="0" Background="#121214" BorderBrush="#27272A" BorderThickness="0,0,1,0" Padding="20">
            <ScrollViewer Name="SidebarScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- AUDIO ROUTING SETUP -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="AUDIO ROUTING SETUP" FontSize="11" FontWeight="Bold" Foreground="#71717A" VerticalAlignment="Center"/>
                        <Button Name="BtnRefreshDevices" Content="↻" Click="BtnRefreshDevices_Click" Style="{StaticResource ModernButtonStyle}" Grid.Column="1" Width="26" Height="26" Padding="0" FontSize="14" ToolTip="Refresh Audio Devices" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- PLAYBACK OUT REGION -->
                    <Border Background="#1A1A1E" CornerRadius="6" Padding="12" Margin="0,0,0,15" BorderBrush="#27272A" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="PLAYBACK OUT" FontSize="11" FontWeight="Bold" Foreground="#10B981" Margin="0,0,0,10"/>

                            <!-- USB Playback -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <RadioButton Name="RadioUsbPlayback" IsChecked="True" GroupName="PlaybackSource" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="USB Playback Out" FontSize="11" Foreground="#A1A1AA" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ComboBox Name="ComboPlayback" Style="{StaticResource DarkComboBoxStyle}" DisplayMemberPath="DisplayName" Margin="0,0,0,10" Height="35">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3B82F6" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#18181B" />
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#18181B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ComboBox.Resources>
                            </ComboBox>

                            <!-- Bluetooth Playback -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <RadioButton Name="RadioBtPlayback" GroupName="PlaybackSource" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Bluetooth Playback Out" FontSize="11" Foreground="#A1A1AA" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ComboBox Name="ComboBluetooth" Style="{StaticResource DarkComboBoxStyle}" DisplayMemberPath="DisplayName" Margin="0,0,0,12" Height="35">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3B82F6" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#18181B" />
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#18181B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ComboBox.Resources>
                            </ComboBox>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Playback Volume" FontSize="11" Foreground="#71717A"/>
                                <TextBlock Name="LblPlaybackVolume" Grid.Column="1" Text="80%" FontSize="11" Foreground="#3B82F6" FontWeight="Bold"/>
                            </Grid>
                            <Slider Name="SliderPlaybackVolume" Minimum="0" Maximum="100" Value="80" ValueChanged="SliderPlaybackVolume_ValueChanged" Margin="0,0,0,5"/>
                        </StackPanel>
                    </Border>

                    <!-- RECORDING IN REGION -->
                    <Border Background="#1A1A1E" CornerRadius="6" Padding="12" Margin="0,0,0,15" BorderBrush="#27272A" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="RECORDING IN" FontSize="11" FontWeight="Bold" Foreground="#3B82F6" Margin="0,0,0,10"/>

                            <TextBlock Text="Recording In" FontSize="11" Foreground="#A1A1AA" Margin="0,0,0,4"/>
                            <ComboBox Name="ComboRecording" Style="{StaticResource DarkComboBoxStyle}" DisplayMemberPath="DisplayName" Margin="0,0,0,12" Height="35">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3B82F6" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#18181B" />
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#18181B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ComboBox.Resources>
                            </ComboBox>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Recording Gain" FontSize="11" Foreground="#71717A"/>
                                <TextBlock Name="LblRecordingGain" Grid.Column="1" Text="100%" FontSize="11" Foreground="#3B82F6" FontWeight="Bold"/>
                            </Grid>
                            <Slider Name="SliderRecordingGain" Minimum="0" Maximum="200" Value="100" ValueChanged="SliderRecordingGain_ValueChanged" Margin="0,0,0,5"/>
                        </StackPanel>
                    </Border>

                    <!-- Test Configuration Limits -->
                    <TextBlock Text="SPECIFICATION LIMITS" FontSize="11" FontWeight="Bold" Foreground="#71717A" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Freq Tol (± dB)" FontSize="11" Foreground="#A1A1AA" Margin="0,0,0,4"/>
                            <TextBox Name="TxtFreqTolerance" Text="3.0" Background="#18181B" BorderBrush="#27272A" Foreground="White" Padding="8,6" Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="THD Limit (%)" FontSize="11" Foreground="#A1A1AA" Margin="0,0,0,4"/>
                            <TextBox Name="TxtThdLimit" Text="0.5" Background="#18181B" BorderBrush="#27272A" Foreground="White" Padding="8,6" Height="32"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#27272A" Margin="0,0,0,20"/>

                    <!-- Action Buttons -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Name="BtnStart" Content="START AUTO TEST" Click="BtnStart_Click" Style="{StaticResource GreenButtonStyle}" FontWeight="Bold" Height="42" Margin="0,0,10,0"/>
                        <Button Name="BtnCancel" Grid.Column="1" Content="Cancel" Click="BtnCancel_Click" Style="{StaticResource RedButtonStyle}" FontWeight="Bold" Width="80" Height="42" IsEnabled="False"/>
                    </Grid>
                    <Button Name="BtnNoiseTest" Content="TEST NOISE FLOOR (SILENCE)" Click="BtnNoiseTest_Click" Style="{StaticResource BlueButtonStyle}" FontWeight="Bold" Margin="0,0,0,20" Height="38" Visibility="Collapsed"/>

                    <!-- Automated Checklist -->
                    <TextBlock Text="TEST SEQUENCE STATUS" FontSize="11" FontWeight="Bold" Foreground="#71717A" Margin="0,0,0,12"/>
                    <ItemsControl Name="ListSteps">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1F1F23" BorderThickness="0,0,0,1" Padding="0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Style="{StaticResource StatusCircleStyle}" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource StatusTextStyle}" FontSize="13"/>
                                            <TextBlock Text="{Binding Details}" Foreground="#71717A" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right Panel (Charts & Verdict) -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Plot Charts Panel -->
            <Grid Grid.Row="0" Margin="15,15,15,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Frequency Response Chart -->
                <Border Name="BorderFreqChart" Grid.Row="0" Background="#121214" BorderBrush="#27272A" BorderThickness="2" CornerRadius="8" Margin="0,0,0,15" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="10,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FREQUENCY RESPONSE ANALYSIS (20 Hz - 20 kHz)" FontSize="12" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                            <TextBlock Name="TxtFreqStatus" Grid.Column="1" Text="" FontSize="11" FontWeight="Bold" Foreground="#FA4B4B" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        </Grid>
                        <ScottPlot:WpfPlot Name="PlotFreqResponse" Grid.Row="1"/>
                    </Grid>
                </Border>

                <!-- THD FFT Spectrum Chart -->
                <Border Name="BorderThdChart" Grid.Row="1" Background="#121214" BorderBrush="#27272A" BorderThickness="2" CornerRadius="8" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="10,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="THD ANALYSIS - FFT SPECTRUM (1 kHz Sine Response)" FontSize="12" FontWeight="Bold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                            <TextBlock Name="TxtThdStatus" Grid.Column="1" Text="" FontSize="11" FontWeight="Bold" Foreground="#FA4B4B" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        </Grid>
                        <ScottPlot:WpfPlot Name="PlotThdFft" Grid.Row="1"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer / Verdict Banner -->
            <Border Grid.Row="1" Background="#121214" BorderBrush="#27272A" BorderThickness="0,1,0,0" Height="85">
                <Grid Margin="15,10">
                    <!-- Overall Verdict Banner -->
                    <Border Name="BorderVerdict" Background="#18181B" BorderThickness="2" BorderBrush="#27272A" CornerRadius="8">
                        <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="OVERALL RESULT" FontSize="11" FontWeight="Bold" Foreground="#71717A" HorizontalAlignment="Center"/>
                                <TextBlock Name="LblVerdict" Text="WAITING..." FontSize="28" FontWeight="Black" Foreground="#A1A1AA" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
