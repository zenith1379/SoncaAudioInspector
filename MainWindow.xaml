<Window x:Class="SoncaAudioInspector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SoncaAudioInspector"
        mc:Ignorable="d"
        Title="Sonca Audio Inspector" Height="780" Width="1200"
        Background="#0E0E10" Foreground="#E4E4E7" WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header Section containing title and tabs -->
            <RowDefinition Height="*"/>    <!-- Content Area -->
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="#18181B" BorderBrush="#27272A" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- Title & Control Row -->
                <Grid Margin="20,10,20,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="SONCA" FontSize="20" FontWeight="Black" Foreground="#10B981"/>
                        <TextBlock Text=" AUDIO INSPECTOR" FontSize="20" FontWeight="Light" Foreground="#F4F4F5"/>
                    </StackPanel>

                    <!-- Staff User Info & Logout Button (Aligned Right) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
                        <TextBlock Name="TxtStaffWelcome" Text="Xin chào, Admin" FontSize="12" Foreground="#A1A1AA" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Name="BtnLogout" Content="Đăng xuất" Click="BtnLogout_Click" Background="#EF4444" Foreground="White" BorderThickness="0" FontSize="11" FontWeight="SemiBold" Padding="10,4" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#27272A" Padding="10,6" CornerRadius="6" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="ASIO / WASAPI Ready" FontSize="11" Foreground="#A1A1AA" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Button Name="BtnToggleFullscreen" Click="BtnToggleFullscreen_Click" Width="30" Height="30" Background="#27272A" BorderThickness="0" Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand" Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="15"/>
                                </Style>
                            </Button.Resources>
                            ⛶
                        </Button>
                        <Button Name="BtnCloseApp" Click="BtnCloseApp_Click" Width="30" Height="30" Background="#EF4444" BorderThickness="0" Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="15"/>
                                </Style>
                            </Button.Resources>
                            ✕
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Serial Number Row & Tab Buttons Row -->
                <Grid Margin="20,5,20,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tab Buttons (Left side) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Name="BtnTabAudioRouting" Content="Audio Routing" Style="{StaticResource TabButtonStyle}" Click="BtnTabAudioRouting_Click"/>
                        <Button Name="BtnTabVisualAI" Content="Ngoại Quan AI" Style="{StaticResource TabButtonStyle}" Margin="10,0,0,0" Click="BtnTabVisualAI_Click"/>
                    </StackPanel>

                    <!-- Serial Number & Model Inputs (Right side) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Model:" FontSize="12" Foreground="#A1A1AA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Name="ComboModels" Width="130" Height="28" Style="{StaticResource DarkComboBoxStyle}" VerticalAlignment="Center" Margin="0,0,20,0" SelectionChanged="ComboModels_SelectionChanged"/>

                        <TextBlock Text="Serial Number:" FontSize="12" Foreground="#A1A1AA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Name="TxtSerialNumber" Width="180" Height="28" Background="#18181B" BorderBrush="#3F3F46" Foreground="White" Padding="6,2" VerticalAlignment="Center" Text="DEFAULT-00001"/>
                        
                        <Button Name="BtnScan" Content="Scan" Click="BtnScan_Click" Background="#27272A" Foreground="White" BorderThickness="0" FontSize="12" Padding="12,4" Height="28" Cursor="Hand" Margin="6,0,0,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Name="BtnAddProduct" Content="Add Product" Click="BtnAddProduct_Click" Background="#10B981" Foreground="White" BorderThickness="0" FontSize="12" Padding="12,4" Height="28" Cursor="Hand" Margin="6,0,0,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Name="BtnCheckStatus" Content="Check Status" Click="BtnCheckStatus_Click" Background="#3B82F6" Foreground="White" BorderThickness="0" FontSize="12" Padding="12,4" Height="28" Cursor="Hand" Margin="6,0,0,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Main Workspace Area -->
        <ContentControl Name="MainContentArea" Grid.Row="1"/>
    </Grid>
</Window>
